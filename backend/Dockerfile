# 1. Выбираем лёгкий и быстрый базовый образ Python
FROM python:3.11-slim

# 2. Устанавливаем рабочую директорию внутри контейнера
WORKDIR /tet-a-tet-backend

# 3. Копируем файл зависимостей первым, чтобы использовать кэш Docker
COPY requirements.txt .

# 4. Устанавливаем зависимости. Флаг --no-cache-dir не сохраняет кэш, экономя место
RUN pip install --no-cache-dir -r requirements.txt

# 5. Копируем весь остальной наш прекрасный код в рабочую директорию
COPY . .

# 6. Открываем порт, на котором будет слушать наше приложение
EXPOSE 8000

# 7. Команда для запуска нашего сервера Uvicorn
# 0.0.0.0 означает, что сервер будет доступен не только внутри контейнера, но и снаружи!
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]